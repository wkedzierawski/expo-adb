{
  "name": "expo-adb",
  "version": "1.0.0",
  "description": "Expo module for running Android ADB shell commands over a local TCP ADB daemon",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./build/index.d.ts",
      "default": "./build/index.js"
    }
  },
  "files": [
    "android/build.gradle",
    "android/src",
    "build",
    "src",
    "expo-module.config.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node internal/module_scripts/build.js",
    "clean": "node internal/module_scripts/clean.js",
    "lint": "eslint src/",
    "test": "node internal/module_scripts/test.js",
    "prepare": "node internal/module_scripts/prepare.js",
    "prepublishOnly": "node internal/module_scripts/prepare.js",
    "open:ios": "node internal/module_scripts/open-ios.js",
    "open:android": "node internal/module_scripts/open-android.js",
    "publish": "npm publish",
    "pack:dry-run": "npm pack --dry-run"
  },
  "keywords": [
    "react-native",
    "expo",
    "expo-adb",
    "ExpoAdb",
    "android",
    "adb",
    "android-tv"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wkedzierawski/expo-adb.git"
  },
  "bugs": {
    "url": "https://github.com/wkedzierawski/expo-adb/issues"
  },
  "author": "Wiktor Kędzierawski <wiktorkedzierawski@gmail.com> (https://github.com/wkedzierawski)",
  "license": "MIT",
  "homepage": "https://github.com/wkedzierawski/expo-adb#readme",
  "dependencies": {},
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/jest": "^29.2.1",
    "@types/react": "~19.1.1",
    "babel-preset-expo": "~55.0.8",
    "eslint": "~9.39.4",
    "eslint-config-universe": "^15.0.3",
    "expo": "^56.0.11",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.9",
    "prettier": "^3.0.0",
    "react-native": "0.82.1",
    "typescript": "^5.9.2"
  },
  "jest": {
    "preset": "jest-expo",
    "roots": [
      "<rootDir>/src"
    ]
  },
  "peerDependencies": {
    "expo": "*",
    "react": "*",
    "react-native": "*"
  },
  "peerDependenciesMeta": {
    "expo": {
      "optional": true
    }
  },
  "directories": {
    "example": "example"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
